{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "checkJs": false,
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@": ["./src/*"],
      "@core/*": ["./src/editors/v1/core/*"],
      "@extensions/*": ["./src/editors/v1/extensions/*"],
      "@features/*": ["./src/editors/v1/features/*"],
      "@components/*": ["./src/editors/v1/components/*"],
      "@helpers/*": ["./src/editors/v1/core/helpers/*"],
      "@utils/*": ["./src/editors/v1/utils/*"],
      "@converter/*": ["./src/editors/v1/core/super-converter/*"],
      "@tests/*": ["./src/editors/v1/tests/*"],
      "@translator": ["./src/editors/v1/core/super-converter/v3/node-translator/"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.js", "**/*.test.ts"]
}
