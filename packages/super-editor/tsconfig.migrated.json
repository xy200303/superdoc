{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": true
  },
  "include": [
    "src/editors/v1/types/**/*.d.ts",
    "src/editors/v1/schema/**/*.d.ts",
    "src/editors/v1/core/Attribute.ts",
    "src/editors/v1/core/EventEmitter.ts",
    "src/editors/v1/core/Extension.ts",
    "src/editors/v1/core/Mark.ts",
    "src/editors/v1/core/Node.ts",
    "src/editors/v1/core/OxmlNode.ts",
    "src/editors/v1/core/PresentationEditor.ts",
    "src/editors/v1/core/commands/core-command-map.d.ts",
    "src/editors/v1/core/helpers/getExtensionConfigField.ts",
    "src/editors/v1/core/header-footer/HeaderFooterRegistry.ts",
    "src/editors/v1/core/types/**/*.ts",
    "src/editors/v1/core/utilities/callOrGet.ts",
    "src/editors/v1/extensions/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js",
    "**/*.test.ts",
    "**/*.test.js",
    "src/editors/v1/core/super-converter",
    "src/editors/v1/core/index.ts",
    "src/editors/v1/core/Editor.ts",
    "src/editors/v1/tests"
  ]
}
